{
  "name": "@alien-protocol/cannon",
  "version": "2.3.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Bulk-create GitHub issues from CSV, PDF, DOCX, JSON or any database — with OAuth login — by Alien Protocol",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "bin": {
    "cannon": "bin/cli.js"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "cannon.config.example.json",
    ".env.example"
  ],
  "scripts": {
    "start": "node bin/cli.js",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
"keywords": [
  "github cli",
  "github issues",
  "github issue automation",
  "bulk github issues",
  "github issue importer",
  "github issue creator",
  "github issue generator",
  "issue automation",
  "issue migration tool",
  "backlog importer",
  "backlog sync github",
  "csv to github issues",
  "json to github issues",
  "database to github issues",
  "bulk issue creator",
  "developer tools",
  "dev productivity",
  "node cli",
  "cli tool",
  "github automation"
],
  "author": "Alien Protocol <https://github.com/Alien-Protocol>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Alien-Protocol/Cannon.git"
  },
  "homepage": "https://github.com/Alien-Protocol/Cannon#readme",
  "bugs": {
    "url": "https://github.com/Alien-Protocol/Cannon/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^13.0.0",
    "csv-parse": "^5.5.5",
    "dotenv": "^16.4.5",
    "mammoth": "^1.7.2",
    "mysql2": "^3.9.7",
    "ora": "^8.0.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.5",
    "sql.js": "^1.12.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3"
  }
}
